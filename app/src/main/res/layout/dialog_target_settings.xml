<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_dark"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configurar Clic #1"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Intervalo de clic (milisegundos):"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <!-- Interval Input -->
    <EditText
        android:id="@+id/edit_interval"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:inputType="number"
        android:text="1000"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_card"
        android:padding="12dp"
        android:textSize="16sp"
        android:layout_marginBottom="20dp" />

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Delete Button -->
        <Button
            android:id="@+id/btn_delete_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eliminar"
            android:backgroundTint="@color/red_error"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="8dp" />

        <!-- Cancel Button -->
        <Button
            android:id="@+id/btn_cancel_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp" />

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guardar"
            android:backgroundTint="@color/primary"
            android:textColor="@color/text_primary" />

    </LinearLayout>

</LinearLayout>
