<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_floating_panel"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <!-- Drag Handle -->
    <ImageView
        android:id="@+id/img_drag"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_drag"
        android:layout_marginEnd="4dp"
        android:padding="4dp"
        android:contentDescription="Arrastrar" />

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:background="@color/float_border"
        android:layout_marginEnd="8dp" />

    <!-- Play/Pause Button -->
    <ImageView
        android:id="@+id/btn_play"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_play"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginEnd="8dp"
        android:padding="6dp"
        android:contentDescription="Iniciar/Pausar" />

    <!-- Add Target Button -->
    <ImageView
        android:id="@+id/btn_add"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_add"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginEnd="8dp"
        android:padding="6dp"
        android:contentDescription="Agregar botón" />

    <!-- Lock Toggle Button -->
    <ImageView
        android:id="@+id/btn_lock"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_lock_open"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginEnd="8dp"
        android:padding="6dp"
        android:contentDescription="Bloquear" />

    <!-- Minimize/Minimize Toggle Target View Button -->
    <ImageView
        android:id="@+id/btn_minimize"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_visibility"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginEnd="8dp"
        android:padding="6dp"
        android:contentDescription="Minimizar" />

    <!-- Anti-Detection Mode Toggle Button -->
    <ImageView
        android:id="@+id/btn_anti_detect"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_security"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginEnd="8dp"
        android:padding="6dp"
        android:contentDescription="Anti-detección" />

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:background="@color/float_border"
        android:layout_marginEnd="8dp" />

    <!-- Close Button -->
    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="6dp"
        android:contentDescription="Cerrar" />

</LinearLayout>
